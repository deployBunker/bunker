{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/kimi-for-coding",
  "small_model": "ollama-cloud/deepseek-v4-flash",
  "instructions": [
    ".opencode/prompt/coding-hermes.md"
  ],
  "permission": {
    "external_directory": "deny",
    "doom_loop": "deny"
  },
  "disabled_providers": [],
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--browserUrl=http://127.0.0.1:12345"],
      "type": "local",
      "enabled": false
    }
  }
}
